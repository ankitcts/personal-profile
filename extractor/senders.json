{
  "$schema_doc": "Each entry under `senders` defines one merchant. Add new merchants by appending entries. See extractor/README.md for the full schema.",
  "senders": [
    {
      "id": "anthropic",
      "name": "Anthropic",
      "match": { "from_domains": ["mail.anthropic.com"] },
      "category": "Subscriptions",
      "amount_patterns": [
        { "regex": "Amount paid\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Receipt from Anthropic[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "apple",
      "name": "Apple",
      "match": { "from_domains": ["email.apple.com"] },
      "category": "Subscriptions",
      "amount_patterns": [
        { "regex": "Total\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "\\$([0-9,]+\\.[0-9]{2})\\s*(?:USD)?", "source": "plain" }
      ]
    },
    {
      "id": "netlify",
      "name": "Netlify",
      "match": { "from_domains": ["netlify.com"], "subject_includes": ["Payment received", "invoice"] },
      "category": "Subscriptions",
      "amount_patterns": [
        { "regex": "\\$([0-9,]+\\.[0-9]{2})\\s+has been charged", "source": "plain" },
        { "regex": "Paid\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "namecheap",
      "name": "Namecheap",
      "match": { "from_domains": ["namecheap.com"], "subject_includes": ["Order Summary"] },
      "category": "Subscriptions",
      "amount_patterns": [
        { "regex": "Final Cost\\s*:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Initial Charge\\s*:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "uwm-mortgage",
      "name": "UWM Mortgage",
      "match": {
        "from_domains": ["loanadministration.com"],
        "subject_includes": ["loan payment", "Payment is Being Processed", "Autopay"]
      },
      "category": "Mortgage",
      "amount_patterns": [
        { "regex": "Payment Amount:\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "monthly mortgage payment[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "audi-financial",
      "name": "Audi Financial",
      "match": { "from_domains": ["finance.audiusa.com"] },
      "category": "Auto",
      "amount_patterns": [
        { "regex": "Payment Amount\\s*:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Total Amount Due\\s*:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "onegold",
      "name": "OneGold",
      "match": { "from_domains": ["onegold.com"], "subject_includes": ["Buy Order", "Payment Received"] },
      "category": "Investments",
      "amount_patterns": [
        { "regex": "payment of \\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Total[:\\s]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "amazon-order",
      "name": "Amazon",
      "match": {
        "from_addresses": ["auto-confirm@amazon.com", "order-update@amazon.com", "shipment-tracking@amazon.com"],
        "subject_includes": ["Ordered:", "Your Amazon.com order"]
      },
      "category": "Shopping",
      "amount_patterns": [
        { "regex": "Order Total:\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Grand Total:\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "html" }
      ]
    },
    {
      "id": "amazon-refund",
      "name": "Amazon refund",
      "match": { "from_addresses": ["return@amazon.com"], "subject_includes": ["refund", "Refund"] },
      "category": "Refunds",
      "amount_patterns": [
        { "regex": "refund of \\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ],
      "amount_sign": "negative"
    },
    {
      "id": "bsw-health",
      "name": "BSW Health",
      "match": { "from_domains": ["bswhealth.org"], "subject_includes": ["payment"] },
      "category": "Healthcare",
      "amount_patterns": [
        { "regex": "Amount:\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "pre-payment of \\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "flywire-medical",
      "name": "Flywire (medical)",
      "match": { "from_domains": ["hc.flywire.com"], "subject_includes": ["Payment Receipt"] },
      "category": "Healthcare",
      "amount_patterns": [
        { "regex": "Payment Amount:\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "txu-energy",
      "name": "TXU Energy",
      "match": { "from_domains": ["notifications.txu.com"], "subject_includes": ["payment", "bill"] },
      "category": "Utilities",
      "amount_patterns": [
        { "regex": "Amount[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Total[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "allstate",
      "name": "Allstate",
      "match": { "from_domains": ["email-allstate.com"], "subject_includes": ["billing", "payment", "policy"] },
      "category": "Insurance",
      "amount_patterns": [
        { "regex": "Amount[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Premium\\s*:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "progressive",
      "name": "Progressive",
      "match": { "from_domains": ["e.progressive.com"] },
      "category": "Insurance",
      "amount_patterns": [
        { "regex": "\\$([0-9,]+(?:\\.[0-9]{2})?)/month", "source": "plain" }
      ]
    },
    {
      "id": "pearson-vue",
      "name": "Pearson VUE",
      "match": { "from_domains": ["e.pearson.com"], "subject_includes": ["Confirmation of Payment"] },
      "category": "Education",
      "amount_patterns": [
        { "regex": "Total:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "html" },
        { "regex": "Total:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "agoda",
      "name": "Agoda",
      "match": { "from_domains": ["agoda.com"], "subject_includes": ["Booking confirmation", "Customer Receipt"] },
      "category": "Travel",
      "amount_patterns": [
        { "regex": "Total[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Amount[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "ntta-parking",
      "name": "DFW NTTA Parking",
      "match": { "from_domains": ["ntta.org"], "subject_includes": ["Parking"] },
      "category": "Travel",
      "amount_patterns": [
        { "regex": "Parking Fee:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "square-pos",
      "name": "Square (POS)",
      "match": { "from_domains": ["messaging.squareup.com"], "subject_includes": ["Receipt from"] },
      "category": "Dining",
      "amount_patterns": [
        { "regex": "Receipt for \\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ]
    },
    {
      "id": "cvs-pharmacy",
      "name": "CVS Pharmacy",
      "match": { "from_domains": ["mynotifications.cvs.com"], "subject_includes": ["got your order"] },
      "category": "Personal Care",
      "amount_patterns": [
        { "regex": "Order Total:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "html" }
      ]
    },
    {
      "id": "aspira-oklahoma",
      "name": "Oklahoma State Parks (AspiraConnect)",
      "match": { "from_domains": ["aspiraconnect.com"], "subject_includes": ["Reservation", "Confirmation"] },
      "category": "Recreation",
      "amount_patterns": [
        { "regex": "Total[^$]*\\$([0-9,]+\\.[0-9]{2})", "source": "html" }
      ]
    },
    {
      "id": "_generic_receipt",
      "name": "Other receipt",
      "match": {
        "subject_includes": ["receipt", "Receipt", "order confirmation", "payment received", "your order"]
      },
      "category": "Uncategorized",
      "amount_patterns": [
        { "regex": "Order Total:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Total:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" },
        { "regex": "Amount:?\\s*\\$([0-9,]+\\.[0-9]{2})", "source": "plain" }
      ],
      "is_fallback": true
    }
  ]
}
